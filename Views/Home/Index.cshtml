@model Avrora.Models.Price.PriceViewModel
@{
    ViewData["Title"] = "Главная";
}


<!-- Герой -->

<section id="Home" class="hero mb-1">
    
    <h1>АВТОМИЙКА</h1>
        <p>Чистота і блиск вашого авто</p>
   <a href="#booking"
       data-bs-toggle="modal"
       data-bs-target="#authModal"
       class="btn">Записатися на мийку
   </a>
</section>

<!-- Услуги -->
<section id="services" class="services hero_2 mb-1 text-white text-center">
    <div class="container"> 
    <h2 class="mb-4">Наші послуги</h2>
    <div id="carouselExampleCaptions" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="2" aria-label="Slide 3"></button>
                <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="3" aria-label="Slide 4"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/car25.jpg" class="d-block w-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                        <h5>@Model.Prices.ElementAt(0).ServiceName</h5>
                        <p>Бистра та акуратна мийка кузова.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/car19.jpg" class="d-block w-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                        <h5>@Model.Prices.ElementAt(1).ServiceName</h5>
                        <p>Кузов, коврики, стікла – все до блиску.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/car22.jpg" class="d-block w-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                        <h5>@Model.Prices.ElementAt(2).ServiceName</h5>
                        <p>Видалим пиль та п'ятна в салоні вашого авто.</p>
                </div>
            </div>
                <div class="carousel-item">
                    <img src="~/images/car23.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption d-none d-md-block">
                        <h5>@Model.Prices.ElementAt(2).ServiceName</h5>
                        <p>Повернемо блиск вашого авто.</p>
                    </div>
                </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
    </div>
</section>

<!-- Цены -->
<section id="prices" class="prices hero_2 mb-1">
    <h2>Ціни на мийку автомобіля</h2>

    <table class="table text-white mt-4">
        @* <tr><th></th><th></th><th>Тип кузова автомобіля</th><th></th></tr> *@
      
        <tr>
            <th></th>
            @foreach(var item in Model.Prices.ElementAt(0).PricesForType)
        {
               
            <th>@item.Key </th>
        }
        </tr>
        
            @foreach(var itemService in Model.Prices)
            {
            <tr>
                <td>  @itemService.ServiceName </td>
                @{
                   @foreach (var itemForType in itemService.PricesForType)
                {
                   
                   @if(itemForType.Value!=null)
                            {
                                <td> @itemForType.Value грн</td>
                                    }
                            else
                            {
                            <td> - </td>
                            }
                            
                   
                }
                }
            </tr>
            }
       </table>

</section>

<!-- О нас -->
<section id="about" class="about hero_2 mb-1">
    <h2>Про нас</h2>
    <p>"Аврора" - це сучасна автомийка, де піклуються про ваш автомобіль.</p>
</section>

<!-- Контакты -->
<section id="contacts" class="contacts hero_2 mb-1">
    <h2>Контакты</h2>
    <p>📍 Адреса: м.Південне, вул. Аврорівська, 22</p>
    <p>📞 Телефон: ‪+38 (050) 111-11-11‬</p>
</section>
